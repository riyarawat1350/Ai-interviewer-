# ========================================
# AI INTERVIEWER — .gitignore
# ========================================

# ── Dependencies ──────────────────────────
node_modules/
*/node_modules/
**/.pnp
**/.pnp.js
.yarn/install-state.gz

# ── Build Outputs ─────────────────────────
dist/
build/
out/
.next/
.nuxt/
.output/
.vite/
client/dist/
server/dist/

# ── Environment & Secrets ─────────────────
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
*.env
server/.env
client/.env

# ── Logs ──────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
server_out.txt

# ── Google Cloud / Credentials ────────────
*credentials*.json
*-credentials.json
google-credentials.json
gcs-credentials.json
service-account*.json
*.pem
*.key
*.p12
*.pfx
!.env.example

# ── Database ──────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Uploads & Generated Files ─────────────
uploads/
server/uploads/
public/uploads/
*.mp3
*.mp4
*.wav
*.webm
!src/**/*.mp3

# ── Cache ─────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache

# ── Testing ───────────────────────────────
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# ── OS Artifacts ──────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── IDEs & Editors ────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ── Misc Temp Files ───────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
*.patch

# ── Docker ────────────────────────────────
# (keep Dockerfile and docker-compose.yml)
.docker/

# ── Large Binaries ────────────────────────
*.exe
*.dmg
*.pkg
*.deb
*.rpm
OllamaSetup.exe

# ── Lock files (keep package-lock.json) ───
yarn.lock
pnpm-lock.yaml
bun.lockb

# ── Type declarations generated ───────────
*.d.ts.map

# ── Vite specific ─────────────────────────
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ── Tailwind JIT cache ────────────────────
.tailwind-cache/

# ── Storybook ─────────────────────────────
storybook-static/
